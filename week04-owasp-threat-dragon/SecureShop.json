            "attrs": { "text": { "text": "Customer\n(Browser)" } },
            "visible": true,
            "shape": "actor",
            "zIndex": 1,
            "id": "actor-customer",
            "data": {
              "type": "tm.Actor",
              "name": "Customer (Browser)",
              "description": "End user of the store; unauthenticated as Guest, authenticated as Customer.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "t-spoof-customer",
                  "title": "Spoofing the Customer",
                  "status": "Open",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "An attacker impersonates a legitimate customer (credential stuffing, session hijacking) to gain access to their account.",
                  "mitigation": "Strong password policy, account lockout/rate limiting, secure session cookies (HttpOnly, Secure, SameSite), optional MFA.",
                  "modelType": "STRIDE"
                }
              ]
            }
          },
          {
            "position": { "x": 40, "y": 420 },
            "size": { "width": 160, "height": 80 },
            "attrs": { "text": { "text": "Admin\n(Browser)" } },
            "visible": true,
            "shape": "actor",
            "zIndex": 1,
            "id": "actor-admin",
            "data": {
              "type": "tm.Actor",
              "name": "Admin (Browser)",
              "description": "Privileged operator who manages catalogue and orders.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "t-eop-admin",
                  "title": "Elevation of privilege via admin endpoints",
                  "status": "Open",
                  "severity": "High",
                  "type": "Elevation of privilege",
                  "description": "A customer reaches admin-only functionality because authorization is enforced only in the UI.",
                  "mitigation": "Server-side role checks on every admin request; deny by default; least privilege; MFA for admins.",
                  "modelType": "STRIDE"
                }
              ]
            }
          },
          {
            "position": { "x": 380, "y": 280 },
            "size": { "width": 160, "height": 100 },
            "attrs": { "text": { "text": "Web / App Server\n(SecureShop)" } },
            "visible": true,
            "shape": "process",
            "zIndex": 1,
            "id": "proc-web",
            "data": {
              "type": "tm.Process",
              "name": "Web / App Server (SecureShop)",
              "description": "Handles requests, business logic, session management, and talks to the DB and payment gateway.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "t-xss-web",
                  "title": "Cross-Site Scripting (XSS)",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "The server reflects/stores untrusted input without encoding, allowing script injection.",
                  "mitigation": "Contextual output encoding, input validation, Content-Security-Policy, framework auto-escaping.",
                  "modelType": "STRIDE"
                },
                {
                  "id": "t-dos-web",
                  "title": "Denial of Service on login/checkout",
                  "status": "Open",
                  "severity": "Medium",
                  "type": "Denial of service",
                  "description": "Flooding expensive endpoints exhausts resources and takes the store offline.",
                  "mitigation": "Rate limiting, reverse proxy/WAF, timeouts, autoscaling, caching.",
                  "modelType": "STRIDE"
                }
              ]
            }
          },
          {
            "position": { "x": 720, "y": 180 },
            "size": { "width": 160, "height": 80 },
            "attrs": { "text": { "text": "User & Order DB" } },
            "visible": true,
            "shape": "store",
            "zIndex": 1,
            "id": "store-db",
            "data": {
              "type": "tm.Store",
              "name": "User & Order DB",
              "description": "Relational store of credentials (hashed), PII, and order history.",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "t-sqli-db",
                  "title": "SQL Injection",
                  "status": "Open",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "Unparameterised queries let an attacker read or modify arbitrary data.",
                  "mitigation": "Parameterised queries / prepared statements; least-privilege DB account; input validation.",
                  "modelType": "STRIDE"
                },
                {
                  "id": "t-info-db",
                  "title": "Information disclosure of PII / credentials",
                  "status": "Open",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "A DB compromise or backup leak exposes personal data and password hashes.",
                  "mitigation": "Encrypt at rest; salted+hashed passwords (bcrypt/argon2); restrict/monitor access; encrypt backups.",
                  "modelType": "STRIDE"
                }
              ]
            }
          },
